{
  "name": "nginux",
  "version": "0.0.1",
  "private": true,
  "description": "NginUX — a friendly, container-native control plane for an Nginx reverse proxy.",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "build": "npm run build --workspace web && npm run build --workspace server",
    "start": "npm run start --workspace server",
    "cli": "node cli/nginux.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "puppeteer-core": "^25.1.0"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
