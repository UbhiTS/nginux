{
  "name": "nginux-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "NginUX desktop app - secure ingress, simplified",
  "author": "Tarunpreet Singh Ubhi",
  "license": "MIT",
  "main": "main.cjs",
  "scripts": {
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.ubhi.nginux",
    "productName": "NginUX",
    "directories": { "output": "out" },
    "files": ["main.cjs"],
    "extraResources": [
      { "from": "payload", "to": "payload" },
      { "from": "runtime", "to": "runtime" }
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Network",
      "synopsis": "Secure ingress, simplified",
      "maintainer": "Tarunpreet Singh Ubhi <ubhits@gmail.com>"
    }
  }
}
