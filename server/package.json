{
  "name": "@nginux/server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "node --watch --experimental-sqlite --disable-warning=ExperimentalWarning src/index.ts",
    "start": "node --experimental-sqlite --disable-warning=ExperimentalWarning src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-sqlite --disable-warning=ExperimentalWarning \"test/**/*.test.ts\"",
    "test:coverage": "node --test --experimental-test-coverage --experimental-sqlite --disable-warning=ExperimentalWarning \"test/**/*.test.ts\""
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "acme-client": "^5.4.0",
    "fastify": "^5.2.0",
    "node-forge": "^1.4.0",
    "nodemailer": "^8.0.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/node-forge": "^1.3.14",
    "@types/nodemailer": "^8.0.0",
    "typescript": "^5.7.2"
  }
}
