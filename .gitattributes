# Normalize line endings. Files that run inside the Linux image MUST be LF -
# CRLF would break the shebang/commands (e.g. "/bin/sh^M: bad interpreter").
* text=auto eol=lf

*.sh        text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.conf      text eol=lf

# Binary assets - never normalize.
*.png binary
*.jpg binary
*.ico binary
*.svg text eol=lf
